{
  "name": "pets",
  "version": "1.0.0",
  "description": "Backend de sistema de petshop com Node.js, Express, Sequelize, MySQL, Swagger e Axios.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:create": "node src/scripts/createDatabase.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "lint:diag": "node -e \"console.log('Use GetDiagnostics no ambiente Trae para verificar diagnosticos.')\""
  },
  "keywords": [
    "nodejs",
    "express",
    "sequelize",
    "mysql",
    "swagger",
    "petshop"
  ],
  "author": "OpenAI",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.2",
    "react-router-dom": "^7.15.1",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
}
